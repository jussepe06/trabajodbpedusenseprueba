<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1114">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hola, estudiante01 👋"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido a tu espacio de bienestar"
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:layout_marginBottom="30dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="#1A1F24"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Riesgo emocional"
                    android:textColor="#94A3B8"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODERADO"
                    android:textColor="#FACC15"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="#1A1F24"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score emocional"
                    android:textColor="#94A3B8"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="78"
                    android:textColor="#67E8F9"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="#1A1F24"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Próxima cita"
                    android:textColor="#94A3B8"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:30 AM"
                    android:textColor="#22C55E"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnCheckin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Realizar check-in emocional"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#67E8F9"/>

    </LinearLayout>

</ScrollView>